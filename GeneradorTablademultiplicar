 # Imprime la tabla de multiplicar de un numero n
while True:
    num = int(input("Ingrese un numero para mostrar su tabla de multiplicar (o 0 para salir): "))
    if num == 0:
        break
    print(f"Tabla de multiplicar del {1,10}:")
    for i in range(1, 11):
        print(f"{num} x {i} = {num * i}")
    print()  # Línea en blanco para separar tablas